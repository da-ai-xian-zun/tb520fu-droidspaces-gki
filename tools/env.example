# Copy to env.local and `source tools/env.local` before building.
# WSL paths; adjust drive letter / clone location.

export REPO_ROOT=/mnt/d/project/tb520fu-droidspaces-gki
export GKI_ROOT=$HOME/tb520fu-gki-r13
export ROOT=$GKI_ROOT

export WIN_PKG_MINIMAL=$REPO_ROOT/packages/triplet-minimal
export WIN_PKG_PHASE2=$REPO_ROOT/packages/triplet-phase2

# Stock boot_a for AVB props (device backup — not redistributed)
export STOCK_BOOT=/path/to/your/stock/boot_a.img

# vbmeta for Release zip / local pack (live SukiSU hashtree-disabled backup)
export PAIR_DIR=/path/to/your/vbmeta-backup-dir
# Expected: vbmeta.current-sukisu-hashtree-disabled.img (65536 B)

# SukiSU-patched init_boot for Release zip (not stored in Git)
export INIT_BOOT_IMG=/path/to/init_boot_a.sukisu-v4.1.3-40796.img

# Lenovo 9008 tools — download yourself (docs/MANUAL_FLASH.md):
# https://mirrors.lolinet.com/firmware/lenowow/2024/Yoga_Tab_Plus_2025/TB520FU/
# → TB520FU_ROW_OPEN_USER_Q00002.0_W_ZUI_17.5.10.096_ST_251127.zip
export ORIGINAL_9008_DIR=/mnt/d/path/to/extracted-lenovo-9008-package
export BASE9008_DIR=$ORIGINAL_9008_DIR